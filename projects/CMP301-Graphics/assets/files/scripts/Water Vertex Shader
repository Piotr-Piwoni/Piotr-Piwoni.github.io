#define C_maxLights 10

cbuffer MatrixBuffer : register(b0)
{
    matrix world;
    matrix view;
    matrix projection;
    matrix lightView[C_maxLights];
    matrix lightProjection[C_maxLights];
};

cbuffer CameraBuffer : register(b1)
{
    float3 cameraPosition;
    float padding;
};

cbuffer DisplacementBuffer : register(b2)
{
    float waveAmplitude;
    float waveFrequency;
    float time;
};

struct InputType
{
    float4 position : POSITION;
    float2 tex : TEXCOORD0;
    float3 normal : NORMAL;
};

struct OutputType
{
    float4 position : SV_POSITION;
    float2 tex : TEXCOORD0;
    float3 normal : NORMAL;
    float3 viewVector : TEXCOORD1;
    float3 worldPosition : TEXCOORD2;
    float4 lightViewPos[C_maxLights] : TEXCOORD3;
};

OutputType main(InputType input)
{
    OutputType output;

    // Apply displacement to vertex position using a sine wave.
    const float displacement = sin(input.position.x * waveFrequency + time) * waveAmplitude;
    input.position.y += displacement;

    float4 worldPos = mul(input.position, world);
    float4 viewPos = mul(worldPos, view);
    output.position = mul(viewPos, projection);

	// Calculate the position of the vertices as viewed by the light source.
    for (int i = 0; i < C_maxLights; ++i)
    {
        float4 lightViewPos = mul(worldPos, lightView[i]);
        lightViewPos = mul(lightViewPos, lightProjection[i]);
        output.lightViewPos[i] = lightViewPos;
    }

    output.worldPosition = worldPos.xyz;

    output.normal = normalize(mul((float3x3) world, input.normal));

    output.viewVector = normalize(cameraPosition - worldPos.xyz);
    output.tex = input.tex;

    return output;
}
